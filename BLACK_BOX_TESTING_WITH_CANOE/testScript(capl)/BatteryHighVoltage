void mainTest()
{
  testModuleTitle("Battery Voltage High 정밀 및 지연 분석");
  
  setupPreCondition(1, 1, 14000); 

  // 1. 지연 분석 테스트
  TC_DET_LONG_WAIT_01();

  // 2. 정밀 타이밍 테스트
  TC_PRE_01(); TC_PRE_02();
  TC_DET_COND2_01(); TC_DET_COND2_02();
  TC_DET_TIME2_01(); TC_DET_TIME2_02();
  TC_DET_COND1_02();
  TC_REC_COND_02();
  TC_DET_RAW_VALUE_15();
  TC_REC_RAW_VALUE_15();
  TC_REC_RAW_VALUE_14();
}
