testcase TC_PRE_01() { testCaseTitle("TC_PRE_01", "Engine Off 시 미검출"); initializeFaultState(); syncAndInject(0, 1, 16000); testWaitForTimeout(510); requestAndVerifyLevel("Check", 0); }
testcase TC_PRE_02() { testCaseTitle("TC_PRE_02", "IGN Off 시 미검출"); initializeFaultState(); syncAndInject(1, 0, 16000); testWaitForTimeout(510); requestAndVerifyLevel("Check", 0); }
testcase TC_DET_COND2_01() { testCaseTitle("TC_DET_COND2_01", "15.5V 유지 확인"); initializeFaultState(); syncAndInject(1, 1, 15500); testWaitForTimeout(510); requestAndVerifyLevel("Check", 0); }
testcase TC_DET_COND2_02() { testCaseTitle("TC_DET_COND2_02", "15.5V 초과 검출"); initializeFaultState(); syncAndInject(1, 1, 15600); testWaitForTimeout(510); requestAndVerifyLevel("Check", 2); }
testcase TC_DET_TIME2_01() { testCaseTitle("TC_DET_TIME2_01", "최소시간 미달(490ms)"); initializeFaultState(); syncAndInject(1, 1, 16000); testWaitForTimeout(490); requestAndVerifyLevel("Check", 0); }
testcase TC_DET_TIME2_02() { testCaseTitle("TC_DET_TIME2_02", "최대시간 도달(510ms)"); initializeFaultState(); syncAndInject(1, 1, 16000); testWaitForTimeout(510); requestAndVerifyLevel("Check", 2); }
testcase TC_DET_COND1_02() { testCaseTitle("TC_DET_COND1_02", "20V 초과 즉시 검출"); initializeFaultState(); syncAndInject(1, 1, 20100); testWaitForTimeout(10); requestAndVerifyLevel("Check", 2); }
testcase TC_REC_COND_02() { testCaseTitle("TC_REC_COND_02", "15.0V 이하 회복"); initializeFaultState(); syncAndInject(1, 1, 16000); testWaitForTimeout(510); requestAndVerifyLevel("Pre", 2); syncAndInject(1, 1, 15000); testWaitForTimeout(110); requestAndVerifyLevel("Check", 1); }

testcase TC_DET_RAW_VALUE_15()
{
  testCaseTitle("TC_DET_RAW_VALUE_15", "Raw 데이터 15 주입 후 제어기 반응 확인 (Long Wait)");

  // 1. 이전 테스트 영향 제거를 위한 초기화
  initializeFaultState();

  // 2. [Sync & Inject] 0x556 메시지와 싱크를 맞춘 직후 Raw 값 15 주입
  // 엔진: Run(1), IGN: On(1), Voltage Raw: 15
  syncAndInject(1, 1, 15); 

  // 3. [Wait] 제어기가 반응할 시간을 충분히 부여 (수동 테스트 시 늦게 반응하는 현상 검증)
  testStep("Observation", "Raw 데이터 주입 후 2,000ms 동안 제어기 상태 변화 관찰");
  testWaitForTimeout(2000); 

  if(!requestAndVerifyLevel("FinalCheck", 2)) 
  {
    testStepFail("Result", "Raw 값 15에 대해 제어기가 예상한 고장 상태로 응답하지 않음.");
  }
}
testcase TC_REC_RAW_VALUE_15()
{
  testCaseTitle("TC_REC_RAW_VALUE_15", "고장 발생 후 Raw 15 주입 시 회복 반응 확인 (Long Wait)");

  // 1. 초기화 및 고장 유도 (예: 16V 주입)
  initializeFaultState();
  
  testStep("Fault_Induction", "고장 유도를 위해 16,000mV(16V) 주입");
  syncAndInject(1, 1, 16000); 
  
  // 고장 확정 시간(500ms + 마진) 대기
  testWaitForTimeout(600); 

  // 2. 고장 상태(Level 2)가 되었는지 먼저 확인
  if(!requestAndVerifyLevel("Pre_Fault_Check", 2))
  {
    testStepFail("Step_Fail", "고장 상태 진입 실패로 인해 회복 테스트를 진행할 수 없음");
    return;
  }

  // 3. [Sync & Inject] Raw 데이터 15 주입 (회복 조건으로 가정)
  testStep("Recovery_Action", "회복 조건 확인을 위해 Raw 데이터 15 주입");
  syncAndInject(1, 1, 15); 

  // 4. [Long Wait] 제어기가 회복 로직을 처리할 시간을 충분히 부여
  testStep("Observation", "Raw 15 주입 후 2,000ms 동안 회복(Level 1) 전이 관찰");
  testWaitForTimeout(2000); 

  // 5. [Verify] 결함 상태가 Level 1(회복/Fixed)로 전이되었는지 확인
  if(!requestAndVerifyLevel("Final_Recovery_Check",2)) 
  {
    testStepFail("Result", "회복 Raw 값 15 주입 후 제어기가 회복 상태로 응답 (기대 값: 2).");
  }
}

