// --- Speed Cases ---
testcase TC_SPD_DET_BVA_02_FaultDetected()
{
  testStep("1.0", "Speed BVA: 255 주입 시 고장 발생 검증");
  if (!setupAndClear("1.1", 1, 1)) return;
  setSignalValue(SIG_SPEED, 255);
  testWaitForTimeout(520 - gStbDelay);
