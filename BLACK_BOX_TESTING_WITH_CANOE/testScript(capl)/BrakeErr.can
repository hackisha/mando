void mainTest()
{
  testModuleTitle("Req 6: Brake Error Validation (Brake, Accel, Speed)");

  TC_PRE_01_NoDetection_When_EngineIsOff();
  TC_PRE_02_NoDetection_When_IgnitionIsOff();

  // 1) Brake Error
  TC_BRK_DET_BVA_01_NoFault_When_BrakeIs126();
  TC_BRK_DET_BVA_02_FaultDetected_When_BrakeIs127();
  TC_BRK_DET_TIM_01_NoFaultBefore489ms();
  TC_BRK_DET_TIM_02_FaultWithin490To510ms();
  TC_BRK_REC_BVA_01_Recovery_When_BrakeIs126();
  TC_BRK_REC_TIM_01_NoRecoveryBefore89ms();
  TC_BRK_REC_TIM_02_RecoveryWithin90To110ms();

  // 2) ACCEL Error
  TC_ACC_DET_BVA_01_NoFault_When_AccelIs126();
  TC_ACC_DET_BVA_02_FaultDetected_When_AccelIs127();
  TC_ACC_DET_TIM_01_NoFaultBefore489ms();
  TC_ACC_DET_TIM_02_FaultWithin490To510ms();
  TC_ACC_REC_BVA_01_Recovery_When_AccelIs126();
  TC_ACC_REC_TIM_01_NoRecoveryBefore89ms();
  TC_ACC_REC_TIM_02_RecoveryWithin90To110ms();

  // 3) Speed Error
  TC_SPD_DET_BVA_01_NoFault_When_SpeedIs254();
  TC_SPD_DET_BVA_02_FaultDetected_When_SpeedIs255();
  TC_SPD_DET_TIM_01_NoFaultBefore489ms();
  TC_SPD_DET_TIM_02_FaultWithin490To510ms();
  TC_SPD_REC_BVA_01_Recovery_When_SpeedIs254();
  TC_SPD_REC_TIM_01_NoRecoveryBefore89ms();
  TC_SPD_REC_TIM_02_RecoveryWithin90To110ms();
}
