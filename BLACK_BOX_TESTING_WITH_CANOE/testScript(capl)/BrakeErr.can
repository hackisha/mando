{
  testStep("1.0", "Setup: Engine=1, IGN=1");
  if (!setupAndClearFault("1.1", 1, 1)) return;
  
  testStep("2.0", "Check: Set Speed=254 and wait 520 ms");
  setSignalValue(SIG_SPEED, 254);
  checkNoFaultForDuration("2.1", SIG_SPEED, 520, 20);
}

