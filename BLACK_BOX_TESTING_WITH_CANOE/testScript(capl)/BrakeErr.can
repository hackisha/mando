// -----------------------------------------------------------------
// 3) 💡 Combinatorial Matrices (Exhaustive 8x8 States)
// -----------------------------------------------------------------

testcase TC_MATRIX_Exhaustive_Detection_8_States()
{
  int i; long b, a, s; long expB, expA, expS; char stepId[20];
  testStep("DET_MATRIX", "=== 고장 검출 조합 매트릭스 테스트 (8가지) ===");
  for (i = 0; i < 8; i++) {
    b = (i & 0x01) ? 127 : 0; a = (i & 0x02) ? 127 : 0; s = (i & 0x04) ? 255 : 0;
    expB = (i & 0x01) ? 2 : 0; expA = (i & 0x02) ? 2 : 0; expS = (i & 0x04) ? 2 : 0;
    snprintf(stepId, 20, "DET_State_%d", i);
    setupPreCondition(1, 1); setAllSignals(b, a, s);
    testWaitForTimeout(510);
    verifyAllStatuses(stepId, expB, expA, expS);
  }
}

testcase TC_MATRIX_Exhaustive_Recovery_8_States()
{
  int i; long b, a, s; long expB, expA, expS; char stepId[20];
  testStep("REC_MATRIX", "=== 고장 회복 조합 매트릭스 테스트 (8가지) ===");
  for (i = 0; i < 8; i++) {
    setupPreCondition(1, 1); setAllSignals(127, 127, 255);
    testWaitForTimeout(510); 
    if (!verifyAllStatuses("REC_INIT", 2, 2, 2)) continue;

    b = (i & 0x01) ? 127 : 0; a = (i & 0x02) ? 127 : 0; s = (i & 0x04) ? 255 : 0;
    expB = (i & 0x01) ? 2 : 1; expA = (i & 0x02) ? 2 : 1; expS = (i & 0x04) ? 2 : 1;
    snprintf(stepId, 20, "REC_State_%d", i);
    setAllSignals(b, a, s);
    testWaitForTimeout(110); 
    verifyAllStatuses(stepId, expB, expA, expS);
  }
}

// -----------------------------------------------------------------
// Main Test Execution
// -----------------------------------------------------------------

void mainTest()
{
  testModuleTitle("Req 6: Ultimate Full Exhaustive Combinatorial Test");

  // A. Combinatorial Matrices
  TC_MATRIX_Exhaustive_Detection_8_States();
  TC_MATRIX_Exhaustive_Recovery_8_States();

  // B. Standard Detailed Test Cases (Expanded)
  TC_PRE_01_NoDetection_When_EngineIsOff();
  TC_PRE_02_NoDetection_When_IgnitionIsOff();

  TC_BRK_DET_BVA_01_NoFault_When_BrakeIs126();
  TC_BRK_DET_BVA_02_FaultDetected_When_BrakeIs127();
  TC_BRK_DET_TIM_01_NoFaultBefore489ms();
  TC_BRK_DET_TIM_02_FaultWithin490To510ms();
  TC_BRK_REC_BVA_01_Recovery_When_BrakeIs126();
  TC_BRK_REC_TIM_02_RecoveryWithin90To110ms();

  TC_ACC_DET_BVA_02_FaultDetected();
  TC_ACC_DET_TIM_02_Precision();
  TC_ACC_REC_TIM_02_Precision();

  TC_SPD_DET_BVA_02_FaultDetected();
  TC_SPD_DET_TIM_02_Precision();
  TC_SPD_REC_TIM_02_Precision();
}
